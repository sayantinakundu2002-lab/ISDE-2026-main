{
  "name": "isde-2026",
  "version": "1.0.0",
  "description": "FastAPI-based e-commerce demo fulfilling ISDE 25/26 course requirements.  \r Implements product catalog, cart management, form-data handling, and automated testing.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "backend": "python scripts/run_backend.py",
    "frontend": "npm run dev --prefix frontend -- --host 0.0.0.0",
    "predev": "python scripts/cleanup.py",
    "start": "npm run dev",
    "dev": "concurrently -k -n BE,FE -c blue,green \"npm run backend\" \"npm run frontend\"",
    "test": "python -m pytest -v",
    "coverage": "python -m pytest --cov=backend --cov-report=term-missing"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-github-username/ISDE-2026.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "bugs": {
    "url": "https://github.com/your-github-username/ISDE-2026/issues"
  },
  "homepage": "https://github.com/your-github-username/ISDE-2026#readme"
}
