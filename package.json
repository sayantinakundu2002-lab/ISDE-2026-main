{
  "name": "isde-2026",
  "version": "1.0.0",
  "description": "FastAPI-based e-commerce demo fulfilling ISDE 25/26 course requirements.  \r Implements product catalog, cart management, form-data handling, and automated testing.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "backend": "python -X utf8 -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "frontend": "npm run dev --prefix frontend -- --host 0.0.0.0",
    "start": "npm run dev",
    "dev": "concurrently -n BE,FE -c blue,green \"npm run backend\" \"npm run frontend\"",
    "test": "python -m pytest -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sayantinakundu2002-lab/ISDE-2026.git"
  },
