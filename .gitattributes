# Force line endings normalization
* text=auto

# Ensure shell scripts always use LF (crucial for execution on Linux/macOS/Codespaces)
*.sh text eol=lf

# Ensure PowerShell scripts always use CRLF (Windows native format)
*.ps1 text eol=crlf

# Ensure batch files always use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
